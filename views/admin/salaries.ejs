<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('../partials/head') %>
    <title>RON OIL Admin — Salari&eacute;s</title>
    <link rel="stylesheet" href="/css/admin-shared.css">
</head>
<body>
    <%- include('../partials/admin-sidebar', { currentPage: 'salaries' }) %>
    <main class="main-content">
        <div class="page-header">
            <div class="page-title">Salari&eacute;s</div>
            <div class="page-subtitle">Gestion des employ&eacute;s Ron Oil</div>
        </div>

        <% const total = employees.length; %>
        <% const cdi = employees.filter(e => e.contract === 'CDI').length; %>
        <% const cdd = employees.filter(e => e.contract === 'CDD').length; %>
        <% const inactive = employees.filter(e => e.status === 'inactive').length; %>

        <div class="g4" style="margin-bottom:28px;">
            <div class="card"><div class="card-label">Total employ&eacute;s</div><div class="card-value c-accent"><%= total %></div></div>
            <div class="card"><div class="card-label">CDI</div><div class="card-value"><%= cdi %></div></div>
            <div class="card"><div class="card-label">CDD</div><div class="card-value c-gold"><%= cdd %></div></div>
            <div class="card"><div class="card-label">Inactifs</div><div class="card-value"><%= inactive %></div></div>
        </div>

        <div class="admin-toolbar">
            <div class="admin-toolbar-left">
                <input type="text" class="admin-search" placeholder="Rechercher un salari&eacute;..." id="search-input" oninput="filterTable()">
            </div>
            <button class="btn-add" onclick="openModal('modal-add')">
                <i class="fa-solid fa-plus"></i> Ajouter un salari&eacute;
            </button>
        </div>

        <div class="card" style="padding:0;overflow:hidden;">
            <table class="admin-table" id="salaries-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nom</th>
                        <th>Contrat</th>
                        <th>Poste</th>
                        <th>Statut</th>
                        <th>Admin</th>
                        <th>Embauche</th>
                        <th>T&eacute;l&eacute;phone</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="salaries-body">
                    <% employees.forEach(function(e, i) { %>
                    <tr class="employee-row" data-employee-id="<%= e.id %>" data-search="<%= (e.firstName + ' ' + e.lastName + ' ' + e.role).toLowerCase() %>">
                        <td class="mono" style="color:var(--text-muted)"><%= i + 1 %></td>
                        <td style="font-weight:500">
                            <% var dutyClass = (e.duty && e.duty.onDuty) ? 'on' : 'off'; %>
                            <% var dutyTitle = e.duty ? ((e.duty.onDuty ? 'En service' : 'Hors service') + ' depuis ' + new Date(e.duty.since).toLocaleString('fr-FR')) : 'Hors service (aucun log)'; %>
                            <span class="duty-dot <%= dutyClass %>" title="<%= dutyTitle %>"></span>
                            <a href="#" class="employee-name-link" onclick="event.preventDefault(); openRecap(<%= e.id %>)" title="Voir le récap"><%= e.firstName %> <%= e.lastName %></a>
                        </td>
                        <td><span class="contract-badge <%= e.contract.toLowerCase() %>"><%= e.contract %></span></td>
                        <td><%= e.role %></td>
                        <td><span class="status-badge <%= e.status === 'active' ? 'active' : 'inactive' %>"><%= e.status === 'active' ? 'Actif' : 'Inactif' %></span></td>
                        <td>
                            <button type="button" class="btn-toggle-admin" onclick="toggleAdmin(<%= e.id %>)" title="<%= e.isAdmin ? 'Révoquer l’accès admin' : 'Donner l’accès admin' %>" style="background:none;border:none;cursor:pointer;padding:0;font-size:16px;color:<%= e.isAdmin ? '#ffb020' : 'var(--text-muted)' %>">
                                <i class="fa-solid <%= e.isAdmin ? 'fa-shield-halved' : 'fa-shield' %>"></i>
                            </button>
                        </td>
                        <td class="mono" style="color:var(--text-secondary)"><%= e.hireDate ? new Date(e.hireDate).toLocaleDateString('fr-FR') : '—' %></td>
                        <td class="mono" style="color:var(--text-secondary)"><%= e.phone || '—' %></td>
                        <td>
                            <div class="table-actions">
                                <button class="btn-edit" onclick="editEmployee(<%= e.id %>)" title="Modifier"><i class="fa-solid fa-pen"></i></button>
                                <button type="button" class="btn-toggle-status" onclick="toggleStatus(<%= e.id %>)" title="<%= e.status === 'active' ? 'Désactiver' : 'Réactiver' %>">
                                    <i class="fa-solid <%= e.status === 'active' ? 'fa-user-slash' : 'fa-user-check' %>"></i>
                                </button>
                                <button type="button" class="btn-delete" onclick="deleteEmployee(<%= e.id %>)" title="Supprimer"><i class="fa-solid fa-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </main>

    <!-- Modal Ajouter -->
    <div class="modal-overlay" id="modal-add">
        <div class="modal">
            <div class="modal-header">
                <div class="modal-title">Ajouter un salari&eacute;</div>
                <button class="modal-close" onclick="closeModal('modal-add')">&#10005;</button>
            </div>
            <form method="POST" action="/admin/salaries">
                <div class="modal-body">
                    <div class="form-grid">
                        <div>
                            <label class="f-label f-required">Pr&eacute;nom</label>
                            <input type="text" class="f-input" name="firstName" placeholder="Pr&eacute;nom" required>
                        </div>
                        <div>
                            <label class="f-label f-required">Nom</label>
                            <input type="text" class="f-input" name="lastName" placeholder="Nom" required>
                        </div>
                        <div>
                            <label class="f-label f-required">Contrat</label>
                            <select class="f-select" name="contract" required>
                                <option value="" disabled selected>S&eacute;lectionner...</option>
                                <option value="CDI">CDI</option>
                                <option value="CDD">CDD</option>
                            </select>
                        </div>
                        <div>
                            <label class="f-label f-required">Poste</label>
                            <select class="f-select" name="role" required>
                                <option value="" disabled selected>S&eacute;lectionner...</option>
                                <option value="Livreur">Livreur</option>
                                <option value="Superviseur">Superviseur</option>
                                <option value="Direction">Direction</option>
                                <option value="PDG">PDG</option>
                            </select>
                        </div>
                        <div>
                            <label class="f-label f-required">T&eacute;l&eacute;phone</label>
                            <input type="text" class="f-input" name="phone" placeholder="555-0000" required>
                        </div>
                        <div>
                            <label class="f-label f-required">Date d'embauche</label>
                            <input type="date" class="f-input" name="hireDate" required>
                        </div>
                        <div>
                            <label class="f-label f-required">Date de fin de contrat</label>
                            <input type="date" class="f-input" name="endDate" required>
                        </div>
                        <div>
                            <label class="f-label">IBAN</label>
                            <input type="text" class="f-input" name="iban" placeholder="IBAN de l'employ&eacute;">
                        </div>
                        <div>
                            <label class="f-label f-required">ID Discord</label>
                            <input type="text" class="f-input" name="discordId" placeholder="ex. 123456789012345678" required>
                        </div>
                        <div class="form-group-full">
                            <label class="f-label">Notes</label>
                            <textarea class="f-textarea" name="notes" placeholder="Informations compl&eacute;mentaires sur l'employ&eacute;..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-secondary" onclick="closeModal('modal-add')">Annuler</button>
                    <button type="submit" class="btn-primary"><i class="fa-solid fa-check"></i> Ajouter</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Modifier -->
    <div class="modal-overlay" id="modal-edit">
        <div class="modal">
            <div class="modal-header">
                <div class="modal-title">Modifier un salari&eacute;</div>
                <button class="modal-close" onclick="closeModal('modal-edit')">&#10005;</button>
            </div>
            <form method="POST" id="form-edit" action="">
                <div class="modal-body">
                    <div class="form-grid">
                        <div>
                            <label class="f-label f-required">Pr&eacute;nom</label>
                            <input type="text" class="f-input" name="firstName" required>
                        </div>
                        <div>
                            <label class="f-label f-required">Nom</label>
                            <input type="text" class="f-input" name="lastName" required>
                        </div>
                        <div>
                            <label class="f-label f-required">Contrat</label>
                            <select class="f-select" name="contract" required>
                                <option value="CDI">CDI</option>
                                <option value="CDD">CDD</option>
                            </select>
                        </div>
                        <div>
                            <label class="f-label f-required">Poste</label>
                            <select class="f-select" name="role" required>
                                <option value="Livreur">Livreur</option>
                                <option value="Superviseur">Superviseur</option>
                                <option value="Direction">Direction</option>
                                <option value="PDG">PDG</option>
                            </select>
                        </div>
                        <div>
                            <label class="f-label">T&eacute;l&eacute;phone</label>
                            <input type="text" class="f-input" name="phone" placeholder="555-0000">
                        </div>
                        <div>
                            <label class="f-label f-required">Date d'embauche</label>
                            <input type="date" class="f-input" name="hireDate" required>
                        </div>
                        <div>
                            <label class="f-label">Date de fin de contrat</label>
                            <input type="date" class="f-input" name="endDate">
                        </div>
                        <div>
                            <label class="f-label">IBAN</label>
                            <input type="text" class="f-input" name="iban" placeholder="IBAN de l'employ&eacute;">
                        </div>
                        <div>
                            <label class="f-label">ID Discord</label>
                            <input type="text" class="f-input" name="discordId" placeholder="ex. 123456789012345678">
                        </div>
                        <div>
                            <label class="f-label">ID Casier (salon Discord)</label>
                            <input type="text" class="f-input" name="casierId" placeholder="ex. 123456789012345678">
                        </div>
                        <div class="form-group-full">
                            <label class="f-label">Notes</label>
                            <textarea class="f-textarea" name="notes" placeholder="Informations compl&eacute;mentaires sur l'employ&eacute;..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-secondary" onclick="closeModal('modal-edit')">Annuler</button>
                    <button type="submit" class="btn-primary"><i class="fa-solid fa-check"></i> Enregistrer</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Récap -->
    <div class="modal-overlay" id="modal-recap">
        <div class="modal" style="width:1100px;">
            <div class="modal-header">
                <div class="modal-title" id="recap-title">Récap salarié</div>
                <button class="modal-close" onclick="closeModal('modal-recap')">&#10005;</button>
            </div>
            <div class="modal-body" id="recap-body">
                <div class="detail-empty"><div class="detail-empty-inner"><i class="fa-solid fa-spinner fa-spin"></i>Chargement…</div></div>
            </div>
        </div>
    </div>

    <style>
        .employee-name-link { color:var(--text-primary); text-decoration:none; cursor:pointer; transition:color .15s; }
        .employee-name-link:hover { color:var(--accent); text-decoration:underline; }
        .recap-section-title { font-family:var(--font-display); font-size:13px; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:var(--text-secondary); margin:0 0 14px; }
        .recap-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:24px; }
        .recap-card { background:var(--bg-card); border:1px solid var(--border); padding:14px 16px; }
        .recap-card-label { font-size:10.5px; letter-spacing:.16em; text-transform:uppercase; color:var(--text-muted); margin-bottom:6px; }
        .recap-card-value { font-family:var(--font-mono); font-size:18px; font-weight:600; }
        .recap-card-sub { font-size:11px; color:var(--text-muted); margin-top:4px; }
        .recap-history-grid { display:grid; grid-template-columns:240px 1fr; gap:18px; }
        .recap-history-list { display:flex; flex-direction:column; gap:5px; max-height:360px; overflow-y:auto; }
        .recap-hi {
            display:flex; align-items:center; justify-content:space-between;
            padding:11px 14px; background:var(--bg-card); border:1px solid var(--border);
            cursor:pointer; transition:border-color .15s, background .15s;
        }
        .recap-hi:hover { border-color:rgba(255,255,255,.1); }
        .recap-hi.active { border-color:var(--accent); background:var(--accent-dim); }
        .recap-hi-week { font-family:var(--font-display); font-size:13px; font-weight:700; }
        .recap-hi-info { font-size:11px; color:var(--text-muted); margin-top:2px; }
        .recap-hi-rank { font-family:var(--font-mono); font-size:13px; font-weight:600; }
        .recap-empty { padding:18px; color:var(--text-muted); text-align:center; font-size:13px; }
    </style>

    <script type="application/json" id="employees-data"><%- JSON.stringify(employees).replace(/</g, '\\u003c') %></script>

    <div class="toast success" id="toast">
        <i class="fa-solid fa-circle-check"></i>
        <span id="toast-msg">Action effectu&eacute;e</span>
    </div>

    <script src="/js/admin-ajax.js"></script>
    <script>
        function filterTable() {
            var q = document.getElementById('search-input').value.toLowerCase();
            var rows = document.querySelectorAll('.employee-row');
            rows.forEach(function(row) {
                var search = row.getAttribute('data-search');
                row.style.display = search.includes(q) ? '' : 'none';
            });
        }

        var employeesData = JSON.parse(document.getElementById('employees-data').textContent);

        // Re-parse le cache JSON après un soft-reload
        window.addEventListener('admin:reloaded', function() {
            var el = document.getElementById('employees-data');
            if (el) employeesData = JSON.parse(el.textContent);
        });

        // Interception des submits add/edit en AJAX
        function hookForm(selector, modalId, successMsg) {
            var form = document.querySelector(selector);
            if (!form) return;
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                AdminAjax.postForm(form).then(function(data) {
                    closeModal(modalId);
                    if (modalId === 'modal-add') form.reset();
                    showToast(successMsg);
                    if (data && data.casierWarning) {
                        setTimeout(function() {
                            showToast('Casier Discord non créé : ' + data.casierWarning, 'error');
                        }, 1500);
                    }
                    return AdminAjax.reloadMain();
                }).catch(function(err) { showToast('Erreur : ' + err.message, 'error'); });
            });
        }
        hookForm('#modal-add form', 'modal-add', 'Salarié ajouté');
        hookForm('#form-edit', 'modal-edit', 'Salarié modifié');

        function toDateInput(value) {
            if (!value) return '';
            return String(value).split('T')[0];
        }

        function editEmployee(id) {
            var emp = employeesData.find(function(e) { return e.id === id; });
            if (!emp) { showToast('Employé introuvable', 'error'); return; }
            var form = document.getElementById('form-edit');
            form.action = '/admin/salaries/' + id + '/edit';
            form.firstName.value = emp.firstName || '';
            form.lastName.value  = emp.lastName  || '';
            form.contract.value  = emp.contract  || 'CDD';
            form.role.value      = emp.role      || 'Livreur';
            form.phone.value     = emp.phone     || '';
            form.hireDate.value  = toDateInput(emp.hireDate);
            form.endDate.value   = toDateInput(emp.endDate);
            form.iban.value      = emp.iban      || '';
            form.discordId.value = emp.discordId || '';
            form.casierId.value  = emp.casierId  || emp.channelId || '';
            form.notes.value     = emp.notes     || '';
            openModal('modal-edit');
        }

        function toggleStatus(id) {
            AdminAjax.post('/admin/salaries/' + id + '/toggle')
                .then(function() { return AdminAjax.reloadMain(); })
                .catch(function(err) { showToast('Erreur : ' + err.message, 'error'); });
        }

        function toggleAdmin(id) {
            AdminAjax.post('/admin/salaries/' + id + '/toggle-admin')
                .then(function() { return AdminAjax.reloadMain(); })
                .catch(function(err) { showToast('Erreur : ' + err.message, 'error'); });
        }

        function deleteEmployee(id) {
            if (!confirm('Supprimer définitivement cet employé ?')) return;
            AdminAjax.post('/admin/salaries/' + id + '/delete')
                .then(function(data) {
                    if (data && data.botWarning) {
                        setTimeout(function() {
                            showToast('Casier Discord non archivé : ' + data.botWarning, 'error');
                        }, 1500);
                    }
                    return AdminAjax.reloadMain();
                })
                .catch(function(err) { showToast('Erreur : ' + err.message, 'error'); });
        }

        var recapState = { history: [], selectedKey: null };
        var fmtMoney = function(n) { return new Intl.NumberFormat('fr-FR').format(Math.round(n || 0)) + '$'; };

        function openRecap(id) {
            openModal('modal-recap');
            var emp = employeesData.find(function(e) { return e.id === id; });
            document.getElementById('recap-title').textContent = emp
                ? 'Récap — ' + emp.firstName + ' ' + emp.lastName
                : 'Récap salarié';
            document.getElementById('recap-body').innerHTML =
                '<div class="detail-empty"><div class="detail-empty-inner"><i class="fa-solid fa-spinner fa-spin"></i>Chargement…</div></div>';

            fetch('/admin/salaries/' + id + '/recap', { credentials: 'same-origin' })
                .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
                .then(function(data) { renderRecap(data); })
                .catch(function(err) {
                    document.getElementById('recap-body').innerHTML =
                        '<div class="recap-empty">Erreur de chargement : ' + err.message + '</div>';
                });
        }

        function renderRecap(data) {
            recapState.history = data.history || [];
            recapState.selectedKey = null;

            var c = data.current || {};
            var currentHtml;
            if (c.empty) {
                currentHtml =
                    '<div class="recap-empty">Aucune activité enregistrée pour cette semaine.</div>';
            } else {
                var primes = (c.bonusSalary || 0) + (c.tierPrime || 0) + (c.podiumPrize || 0) + (c.specialBonus || 0);
                var frais = (c.expenseRefund || 0) + (c.repatBonus || 0) + (c.impoundReimbursement || 0);
                var finaleColor = (c.primeFinale || 0) >= 0 ? 'c-success' : 'c-danger';
                var finaleSign = (c.primeFinale || 0) >= 0 ? '+' : '-';
                currentHtml =
                    '<div class="recap-grid">' +
                        '<div class="recap-card"><div class="recap-card-label">Rang</div><div class="recap-card-value">#' + (c.rank || '—') + '</div></div>' +
                        '<div class="recap-card"><div class="recap-card-label">Livraisons</div><div class="recap-card-value c-accent">' + (c.deliveries || 0) + '</div></div>' +
                        '<div class="recap-card"><div class="recap-card-label">Gain entreprise</div><div class="recap-card-value c-gold">' + fmtMoney(c.gainEnterprise) + '</div></div>' +
                        '<div class="recap-card"><div class="recap-card-label">Gain employé</div><div class="recap-card-value">' + fmtMoney(c.gainEmployee) + '</div></div>' +
                        '<div class="recap-card"><div class="recap-card-label">Prime de livraisons</div><div class="recap-card-value">' + fmtMoney(c.bonusSalary) + '</div></div>' +
                        '<div class="recap-card"><div class="recap-card-label">Prime palier</div><div class="recap-card-value">' + fmtMoney(c.tierPrime) + '<div class="recap-card-sub">Palier ' + (c.tierLevel || 0) + '</div></div></div>' +
                        '<div class="recap-card"><div class="recap-card-label">Prime podium</div><div class="recap-card-value c-gold">' + fmtMoney(c.podiumPrize) + '</div></div>' +
                        '<div class="recap-card"><div class="recap-card-label">Prime spéciale</div><div class="recap-card-value c-accent">' + fmtMoney(c.specialBonus) +
                            (c.specialBonusReason ? '<div class="recap-card-sub">' + escapeHtml(c.specialBonusReason) + '</div>' : '') + '</div></div>' +
                        '<div class="recap-card"><div class="recap-card-label">Notes de frais</div><div class="recap-card-value">' + fmtMoney(c.expenseRefund) + '<div class="recap-card-sub">sur ' + fmtMoney(c.expenseCost) + ' déclarés</div></div></div>' +
                        '<div class="recap-card"><div class="recap-card-label">Rapatriements</div><div class="recap-card-value">' + fmtMoney(c.repatBonus) + '<div class="recap-card-sub">' + (c.repatCount || 0) + ' évt.</div></div></div>' +
                        '<div class="recap-card"><div class="recap-card-label">Fourrières</div><div class="recap-card-value c-danger">-' + fmtMoney(c.impoundPenalty) + '<div class="recap-card-sub">' + (c.impoundCount || 0) + ' évt.</div></div></div>' +
                        '<div class="recap-card"><div class="recap-card-label">Prime finale</div><div class="recap-card-value ' + finaleColor + '">' + finaleSign + fmtMoney(Math.abs(c.primeFinale || 0)) + '</div></div>' +
                    '</div>';
            }

            var historyListHtml;
            if (recapState.history.length === 0) {
                historyListHtml = '<div class="recap-empty">Aucun historique figé.</div>';
            } else {
                historyListHtml = '<div class="recap-history-list">' + recapState.history.map(function(h, i) {
                    var rankColor = h.rank <= 3 ? 'var(--gold)' : 'var(--text-secondary)';
                    return '<div class="recap-hi" id="recap-hi-' + i + '" onclick="selectRecapWeek(' + i + ')">' +
                        '<div><div class="recap-hi-week">S' + h.week + ' &middot; ' + h.year + '</div>' +
                        '<div class="recap-hi-info">' + h.deliveries + ' livr. &middot; Palier ' + h.tierLevel + '</div></div>' +
                        '<div class="recap-hi-rank" style="color:' + rankColor + '">#' + h.rank + '</div>' +
                    '</div>';
                }).join('') + '</div>';
            }

            document.getElementById('recap-body').innerHTML =
                '<div class="recap-section-title">Semaine en cours — S' + (c.week || '?') + '</div>' +
                currentHtml +
                '<div class="recap-section-title">Historique</div>' +
                '<div class="recap-history-grid">' +
                    '<div>' + historyListHtml + '</div>' +
                    '<div id="recap-detail">' +
                        '<div class="detail-empty"><div class="detail-empty-inner"><i class="fa-solid fa-clock-rotate-left"></i>Sélectionnez une semaine pour afficher le détail</div></div>' +
                    '</div>' +
                '</div>';
        }

        function selectRecapWeek(i) {
            var h = recapState.history[i];
            if (!h) return;
            recapState.selectedKey = i;
            document.querySelectorAll('.recap-hi').forEach(function(el) { el.classList.remove('active'); });
            var node = document.getElementById('recap-hi-' + i);
            if (node) node.classList.add('active');

            var primes = (h.bonusSalary || 0) + (h.tierPrime || 0) + (h.podiumPrize || 0) + (h.specialBonus || 0);
            var frais = (h.expenseRefund || 0) + (h.repatBonus || 0) + (h.impoundReimbursement || 0);
            var finaleColor = (h.primeFinale || 0) >= 0 ? 'c-success' : 'c-danger';
            var finaleSign = (h.primeFinale || 0) >= 0 ? '+' : '-';
            document.getElementById('recap-detail').innerHTML =
                '<div class="recap-grid" style="grid-template-columns:repeat(3,1fr);">' +
                    '<div class="recap-card"><div class="recap-card-label">Livraisons</div><div class="recap-card-value c-accent">' + (h.deliveries || 0) + '</div></div>' +
                    '<div class="recap-card"><div class="recap-card-label">Gain entreprise</div><div class="recap-card-value c-gold">' + fmtMoney(h.gainEnterprise) + '</div></div>' +
                    '<div class="recap-card"><div class="recap-card-label">Gain employé</div><div class="recap-card-value">' + fmtMoney(h.gainEmployee) + '</div></div>' +
                    '<div class="recap-card"><div class="recap-card-label">Prime de livraisons</div><div class="recap-card-value">' + fmtMoney(h.bonusSalary) + '</div></div>' +
                    '<div class="recap-card"><div class="recap-card-label">Prime palier</div><div class="recap-card-value">' + fmtMoney(h.tierPrime) + '<div class="recap-card-sub">Palier ' + (h.tierLevel || 0) + '</div></div></div>' +
                    '<div class="recap-card"><div class="recap-card-label">Prime podium</div><div class="recap-card-value c-gold">' + fmtMoney(h.podiumPrize) + '</div></div>' +
                    '<div class="recap-card"><div class="recap-card-label">Prime spéciale</div><div class="recap-card-value c-accent">' + fmtMoney(h.specialBonus) +
                        (h.specialBonusReason ? '<div class="recap-card-sub">' + escapeHtml(h.specialBonusReason) + '</div>' : '') + '</div></div>' +
                    '<div class="recap-card"><div class="recap-card-label">Notes de frais</div><div class="recap-card-value">' + fmtMoney(h.expenseRefund) + '<div class="recap-card-sub">sur ' + fmtMoney(h.expenseCost) + ' déclarés</div></div></div>' +
                    '<div class="recap-card"><div class="recap-card-label">Rapatriements</div><div class="recap-card-value">' + fmtMoney(h.repatBonus) + '<div class="recap-card-sub">' + (h.repatCount || 0) + ' évt.</div></div></div>' +
                    '<div class="recap-card"><div class="recap-card-label">Fourrières</div><div class="recap-card-value c-danger">-' + fmtMoney(h.impoundPenalty) + '<div class="recap-card-sub">' + (h.impoundCount || 0) + ' évt.</div></div></div>' +
                    '<div class="recap-card"><div class="recap-card-label">Prime finale</div><div class="recap-card-value ' + finaleColor + '">' + finaleSign + fmtMoney(Math.abs(h.primeFinale || 0)) + '</div></div>' +
                '</div>';
        }

        function escapeHtml(s) {
            return String(s == null ? '' : s)
                .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
        }

        function openModal(id) {
            var overlay = document.getElementById(id);
            overlay.classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeModal(id) {
            var overlay = document.getElementById(id);
            overlay.classList.remove('open');
            document.body.style.overflow = '';
        }

        function showToast(msg, type) {
            type = type || 'success';
            var t = document.getElementById('toast');
            document.getElementById('toast-msg').textContent = msg;
            t.className = 'toast ' + type + ' show';
            setTimeout(function() { t.classList.remove('show'); }, 3500);
        }

        // Outside-click-to-close modals
        document.querySelectorAll('.modal-overlay').forEach(function(overlay) {
            var downTarget = null;
            overlay.addEventListener('mousedown', function(e) { downTarget = e.target; });
            overlay.addEventListener('mouseup', function(e) {
                if (downTarget === overlay && e.target === overlay) {
                    overlay.classList.remove('open');
                    document.body.style.overflow = '';
                }
                downTarget = null;
            });
        });
    </script>
    <script src="/js/auto-refresh.js"></script>
</body>
</html>
