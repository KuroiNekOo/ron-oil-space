<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('../partials/head') %>
    <title>RON OIL Admin — Services</title>
    <link rel="stylesheet" href="/css/admin-shared.css">
</head>
<body>
    <%- include('../partials/admin-sidebar', { currentPage: 'services' }) %>
    <main class="main-content">
        <div class="page-header">
            <div class="page-title">Services</div>
            <div class="page-subtitle">Prises et fins de service</div>
        </div>

        <form class="admin-toolbar" method="GET" action="/admin/services" style="display:flex;gap:8px;align-items:center;">
            <input type="text" class="admin-search" placeholder="Rechercher un employ&eacute;..." name="q" value="<%= query.q || '' %>">
            <% if (query.q) { %><a href="/admin/services" style="font-size:12px;color:var(--text-muted);">R&eacute;initialiser</a><% } %>
        </form>

        <div class="card" style="padding:0;overflow:hidden;">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Semaine</th>
                        <th>Date / Heure</th>
                        <th>Employ&eacute;(e)</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (rows.length === 0) { %>
                        <tr><td colspan="4" style="text-align:center;padding:40px;color:var(--text-muted)">Aucun enregistrement</td></tr>
                    <% } %>
                    <% rows.forEach(function(r) { %>
                    <tr>
                        <td><span style="font-family:var(--font-mono);font-size:13px;color:var(--accent)">S<%= r.week %></span></td>
                        <td class="mono" style="color:var(--text-secondary);font-size:12px"><%= new Date(r.timestamp).toLocaleString('fr-FR') %></td>
                        <td style="font-weight:500"><%= r.employee %></td>
                        <td><span class="status-badge <%= r.onDuty ? 'active' : 'pending' %>"><%= r.onDuty ? 'Prise de service' : 'Fin de service' %></span></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            <%- include('../partials/pagination', { page, totalPages, total, query }) %>
        </div>
    </main>
    <script src="/js/search-autosubmit.js"></script>
    <script src="/js/auto-refresh.js"></script>
</body>
</html>
