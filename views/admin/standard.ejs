<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('../partials/head') %>
    <title>RON OIL Admin — Standard</title>
    <link rel="stylesheet" href="/css/admin-shared.css">
</head>
<body>
    <%- include('../partials/admin-sidebar', { currentPage: 'standard' }) %>
    <main class="main-content">
        <div class="page-header">
            <div class="page-title">Standard</div>
            <div class="page-subtitle">Appels t&eacute;l&eacute;phoniques re&ccedil;us</div>
        </div>

        <form class="admin-toolbar" method="GET" action="/admin/standard" style="display:flex;gap:8px;align-items:center;">
            <input type="text" class="admin-search" placeholder="Rechercher un num&eacute;ro, &eacute;tat..." name="q" value="<%= query.q || '' %>">
            <% if (query.q) { %><a href="/admin/standard" style="font-size:12px;color:var(--text-muted);">R&eacute;initialiser</a><% } %>
        </form>

        <div class="card" style="padding:0;overflow:hidden;">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Semaine</th>
                        <th>Date / Heure</th>
                        <th>Num&eacute;ro</th>
                        <th>R&eacute;pondu</th>
                        <th>Dur&eacute;e</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (rows.length === 0) { %>
                        <tr><td colspan="5" style="text-align:center;padding:40px;color:var(--text-muted)">Aucun enregistrement</td></tr>
                    <% } %>
                    <% rows.forEach(function(r) { %>
                    <tr>
                        <td><span style="font-family:var(--font-mono);font-size:13px;color:var(--accent)">S<%= r.week %></span></td>
                        <td class="mono" style="color:var(--text-secondary);font-size:12px"><%= new Date(r.timestamp).toLocaleString('fr-FR') %></td>
                        <td style="font-weight:500" class="mono"><%= r.phoneNumber %></td>
                        <td><span class="status-badge <%= r.answered ? 'active' : 'inactive' %>"><%= r.answered ? 'Oui' : 'Non' %></span></td>
                        <td class="mono" style="font-size:12px">
                            <% if (r.duration === 0) { %>—<% } else { %>
                                <% var m = Math.floor(r.duration / 60); var s = r.duration % 60; %>
                                <%= m > 0 ? m + 'm ' : '' %><%= s %>s
                            <% } %>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            <%- include('../partials/pagination', { page, totalPages, total, query }) %>
        </div>
    </main>
    <script src="/js/search-autosubmit.js"></script>
    <script src="/js/auto-refresh.js"></script>
</body>
</html>
