<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('../partials/head') %>
    <title>RON OIL — Pannes</title>
    <link rel="stylesheet" href="/css/shared.css">
</head>
<body>
    <%- include('../partials/employee-sidebar', { currentPage: 'pannes', employee: employee, currentWeek: currentWeek }) %>

    <main class="main-content">
        <div class="page-header">
            <div class="page-title">D&eacute;claration de panne</div>
            <div class="page-subtitle">Formulaire de d&eacute;claration</div>
        </div>

        <div class="form-page-layout">
            <div class="form-page-sidebar">
                <div class="form-page-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
                <div class="form-page-title">Panne</div>
                <div class="form-page-desc">Signalez une panne ou un dysfonctionnement sur un v&eacute;hicule. Soyez le plus pr&eacute;cis possible sur la localisation et la nature du probl&egrave;me.</div>
                <div class="form-autofill-stack">
                    <div class="form-autofill-item">
                        <div class="form-autofill-label">Semaine</div>
                        <div class="form-autofill-val" id="f-week"><%= currentWeek %></div>
                    </div>
                    <div class="form-autofill-item">
                        <div class="form-autofill-label">Horodatage</div>
                        <div class="form-autofill-val" id="f-timestamp">—</div>
                    </div>
                    <div class="form-autofill-item">
                        <div class="form-autofill-label">Employ&eacute;</div>
                        <div class="form-autofill-val"><%= employee.firstName %> <%= employee.lastName %></div>
                    </div>
                </div>
            </div>
            <div class="form-page-main">
                <form class="form-card" id="main-form" method="POST" action="/pannes">
                    <div class="form-grid">
                        <div>
                            <label class="f-label">Plaque du camion</label>
                            <select class="f-select" name="plaqueCamion">
                                <option value="" selected>S&eacute;lectionner un camion...</option>
                                <% trucks.forEach(function(v) { %>
                                    <option value="<%= v.plate %>"><%= v.plate %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div>
                            <label class="f-label">Plaque de la citerne</label>
                            <select class="f-select" name="plaqueCiterne">
                                <option value="" selected>S&eacute;lectionner une citerne...</option>
                                <% tankers.forEach(function(v) { %>
                                    <option value="<%= v.plate %>"><%= v.plate %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div>
                            <label class="f-label f-required">Type de panne</label>
                            <select class="f-select" name="type" required>
                                <option value="" disabled selected>S&eacute;lectionner...</option>
                                <option value="moteur">Moteur</option>
                                <option value="pneu">Pneu / Roue</option>
                                <option value="electricite">&Eacute;lectricit&eacute;</option>
                                <option value="citerne">Citerne</option>
                                <option value="freins">Freins</option>
                                <option value="accident">Accident</option>
                                <option value="autre">Autre</option>
                            </select>
                        </div>
                        <div>
                            <label class="f-label">Position</label>
                            <input type="text" class="f-input" name="position" placeholder="Localisation approximative">
                        </div>
                        <div class="form-group-full">
                            <label class="f-label">Commentaire</label>
                            <textarea class="f-textarea" name="comment" placeholder="D&eacute;crivez la panne en d&eacute;tail (optionnel)..."></textarea>
                        </div>
                    </div>

                    <div class="form-submit-row">
                        <button type="reset" class="btn-reset-form">R&eacute;initialiser</button>
                        <button type="submit" class="btn-submit-form">
                            <i class="fa-solid fa-paper-plane"></i> Envoyer
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <div class="toast success" id="toast">
        <i class="fa-solid fa-circle-check"></i>
        <span id="toast-msg">Formulaire envoy&eacute; avec succ&egrave;s</span>
    </div>

    <script>
        function pad2(n) { return String(n).padStart(2, '0'); }
        const now = new Date();
        document.getElementById('f-timestamp').textContent =
            now.getDate() + '/' + pad2(now.getMonth()+1) + '/' + now.getFullYear() + ' ' + pad2(now.getHours()) + ':' + pad2(now.getMinutes());

        <% if (success) { %>
            (function() {
                const t = document.getElementById('toast');
                t.className = 'toast success show';
                setTimeout(() => t.classList.remove('show'), 3500);
            })();
        <% } %>
    </script>
    <script src="/js/employee-form.js"></script>
</body>
</html>
