<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('../partials/head') %>
    <title>RON OIL — Classement</title>
    <link rel="stylesheet" href="/css/shared.css">
    <style>
        /* Podium Cards */
        .podium-cards {
            display: grid;
            grid-template-columns: 1fr 1.15fr 1fr;
            gap: 14px;
            margin-bottom: 32px;
            align-items: end;
        }
        .podium-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            padding: 28px 18px 24px;
            text-align: center;
            position: relative;
        }
        .podium-gold {
            border-color: rgba(245,166,35,.35);
            background: linear-gradient(180deg, rgba(245,166,35,.08) 0%, var(--bg-card) 60%);
            padding-top: 36px;
        }
        .podium-silver {
            border-color: rgba(184,194,208,.2);
            background: linear-gradient(180deg, rgba(184,194,208,.05) 0%, var(--bg-card) 60%);
        }
        .podium-bronze {
            border-color: rgba(205,139,66,.2);
            background: linear-gradient(180deg, rgba(205,139,66,.05) 0%, var(--bg-card) 60%);
        }
        .podium-crown {
            position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
            color: var(--gold); font-size: 22px;
            filter: drop-shadow(0 2px 8px rgba(245,166,35,.4));
        }
        .podium-rank-icon {
            position: absolute; top: -10px; left: 50%; transform: translateX(-50%);
            font-size: 16px;
        }
        .podium-silver .podium-rank-icon { color: var(--silver); }
        .podium-bronze .podium-rank-icon { color: var(--bronze); }
        .podium-position {
            font-family: var(--font-display);
            font-size: 11px; font-weight: 800;
            letter-spacing: .18em; color: var(--text-muted);
            margin-bottom: 14px;
        }
        .podium-gold .podium-position { color: var(--gold); }
        .podium-silver .podium-position { color: var(--silver); }
        .podium-bronze .podium-position { color: var(--bronze); }
        .podium-ava {
            width: 48px; height: 48px; margin: 0 auto 12px;
            display: flex; align-items: center; justify-content: center;
            font-family: var(--font-display); font-size: 15px; font-weight: 800;
            color: white; background: var(--bg-card-hover);
            border: 2px solid var(--border);
        }
        .podium-ava.gold {
            background: var(--accent);
            border-color: var(--accent);
            box-shadow: 0 4px 20px rgba(255,84,34,.3);
        }
        .podium-name {
            font-family: var(--font-display);
            font-size: 14px; font-weight: 700;
            margin-bottom: 4px;
        }
        .podium-gold .podium-name { color: var(--gold); font-size: 15px; }
        .podium-deliveries {
            font-family: var(--font-mono);
            font-size: 11.5px; color: var(--text-muted);
        }

        /* Classement List */
        .cl-list {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .cl-row {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 14px 20px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            transition: border-color .15s, background .15s;
        }
        .cl-row:hover { border-color: rgba(255,255,255,.12); background: var(--bg-card-hover); }
        .cl-self {
            border-color: var(--border-accent);
            background: linear-gradient(90deg, var(--accent-dim) 0%, var(--bg-card) 40%);
        }
        .cl-rank {
            font-family: var(--font-mono);
            font-size: 18px; font-weight: 700;
            min-width: 32px; text-align: center;
        }
        .cl-ava {
            width: 36px; height: 36px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
            font-family: var(--font-display); font-size: 11px; font-weight: 800;
            background: var(--bg-card-hover); color: var(--text-secondary);
            border: 1px solid var(--border);
        }
        .cl-ava-self {
            background: var(--accent); color: white;
            border-color: var(--accent);
        }
        .cl-info { flex: 1; min-width: 0; }
        .cl-name {
            font-size: 13.5px; font-weight: 500;
            display: flex; align-items: center; gap: 8px;
            margin-bottom: 8px;
        }
        .cl-you {
            font-size: 9px; letter-spacing: .14em; font-weight: 700;
            color: var(--accent);
            padding: 2px 8px;
            background: var(--accent-dim);
            border: 1px solid var(--border-accent);
        }
        .cl-bar-track {
            height: 4px;
            background: rgba(255,255,255,.06);
            border-radius: 2px;
            overflow: hidden;
        }
        .cl-bar-fill {
            height: 100%;
            border-radius: 2px;
            transition: width 1s cubic-bezier(.4,0,.2,1);
        }
        .cl-del {
            display: flex; align-items: baseline; gap: 4px;
            flex-shrink: 0;
        }
        .cl-del-val {
            font-family: var(--font-mono);
            font-size: 18px; font-weight: 600;
            color: var(--text-primary);
        }
        .cl-del-label {
            font-size: 10px; letter-spacing: .1em;
            color: var(--text-muted); text-transform: uppercase;
        }
    </style>
</head>
<body>
    <%- include('../partials/employee-sidebar', { currentPage: 'classement', employee: employee, currentWeek: currentWeek }) %>

    <main class="main-content">

        <div class="page-header">
            <div class="page-title">Classement</div>
            <div class="page-subtitle">
                Semaine <%= currentWeek %> — Classement hebdomadaire
            </div>
        </div>

        <%
            const initials = name => name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2);
            // Tri : rangs 1..N d'abord, puis "non classés" (rank=0) en queue.
            const sorted = [...leaderboard].sort((a, b) => (a.rank || 999) - (b.rank || 999));
            const top3 = sorted.filter(p => p.rank >= 1 && p.rank <= 3);
            const byRank = r => top3.find(p => p.rank === r);
            const maxDel = sorted[0] ? sorted[0].deliveries : 1;

            const p1 = byRank(1);
            const p2 = byRank(2);
            const p3 = byRank(3);
        %>

        <!-- Podium visuel -->
        <div class="podium-cards">
            <div class="podium-card podium-silver">
                <div class="podium-rank-icon"><i class="fa-solid fa-medal"></i></div>
                <div class="podium-position">2</div>
                <% if (p2) { %>
                    <div class="podium-ava"><%= initials(p2.employee.firstName + ' ' + p2.employee.lastName) %></div>
                    <div class="podium-name"><%= p2.employee.firstName %> <%= p2.employee.lastName %></div>
                    <div class="podium-deliveries"><%= p2.deliveries %> livraisons</div>
                <% } else { %>
                    <div class="podium-ava">—</div>
                    <div class="podium-name">—</div>
                    <div class="podium-deliveries">— livraisons</div>
                <% } %>
            </div>
            <div class="podium-card podium-gold">
                <div class="podium-crown"><i class="fa-solid fa-crown"></i></div>
                <div class="podium-position">1</div>
                <% if (p1) { %>
                    <div class="podium-ava gold"><%= initials(p1.employee.firstName + ' ' + p1.employee.lastName) %></div>
                    <div class="podium-name"><%= p1.employee.firstName %> <%= p1.employee.lastName %></div>
                    <div class="podium-deliveries"><%= p1.deliveries %> livraisons</div>
                <% } else { %>
                    <div class="podium-ava gold">—</div>
                    <div class="podium-name">—</div>
                    <div class="podium-deliveries">— livraisons</div>
                <% } %>
            </div>
            <div class="podium-card podium-bronze">
                <div class="podium-rank-icon"><i class="fa-solid fa-medal"></i></div>
                <div class="podium-position">3</div>
                <% if (p3) { %>
                    <div class="podium-ava"><%= initials(p3.employee.firstName + ' ' + p3.employee.lastName) %></div>
                    <div class="podium-name"><%= p3.employee.firstName %> <%= p3.employee.lastName %></div>
                    <div class="podium-deliveries"><%= p3.deliveries %> livraisons</div>
                <% } else { %>
                    <div class="podium-ava">—</div>
                    <div class="podium-name">—</div>
                    <div class="podium-deliveries">— livraisons</div>
                <% } %>
            </div>
        </div>

        <!-- Classement complet -->
        <div class="section-title">Classement complet</div>
        <div class="cl-list">
            <% sorted.forEach(function(p) { %>
                <%
                    const fullName = p.employee.firstName + ' ' + p.employee.lastName;
                    const pct = maxDel > 0 ? Math.round((p.deliveries / maxDel) * 100) : 0;
                    const isSelf = p.employeeId === employee.id;
                    const isTop3 = p.rank >= 1 && p.rank <= 3;
                    const rankColor = p.rank === 1 ? 'var(--gold)' : p.rank === 2 ? 'var(--silver)' : p.rank === 3 ? 'var(--bronze)' : 'var(--text-muted)';
                    const barColor = isSelf ? 'var(--accent)' : isTop3 ? rankColor : 'rgba(255,255,255,.12)';
                %>
                <div class="cl-row <%= isSelf ? 'cl-self' : '' %>">
                    <div class="cl-rank" style="color:<%= rankColor %>"><%= p.rank || '—' %></div>
                    <div class="cl-ava <%= isSelf ? 'cl-ava-self' : '' %>"><%= initials(fullName) %></div>
                    <div class="cl-info">
                        <div class="cl-name">
                            <%= fullName %>
                            <% if (isSelf) { %>
                                <span class="cl-you">VOUS</span>
                            <% } %>
                        </div>
                        <div class="cl-bar-track">
                            <div class="cl-bar-fill" style="width:<%= pct %>%;background:<%= barColor %>;"></div>
                        </div>
                    </div>
                    <div class="cl-del">
                        <span class="cl-del-val"><%= p.deliveries %></span>
                        <span class="cl-del-label">livr.</span>
                    </div>
                </div>
            <% }); %>
        </div>

    </main>
    <script src="/js/auto-refresh.js"></script>
</body>
</html>
