DATABASE_URL="file:./dev.db"
SESSION_SECRET="ron-oil-session-secret-change-me"
PORT=3000

# API du bot Discord (ron-bot-v2)
BOT_API_URL=http://localhost:3001
BOT_API_SECRET=

# Secret utilisé par le script Apps Script du Google Sheet pour envoyer les logs
LOGS_API_SECRET=

# Scheduler web (rollover hebdo + alertes contrats)
PERIOD_START_HOUR=18
CONTRACT_ALERT_HOURS=48
# Fréquence de vérification des contrats (minutes). 1440 = 1 fois par jour.
# Un contrat déjà alerté n'est jamais ré-alerté (sauf renouvellement = changement de endDate).
CONTRACT_CHECK_INTERVAL_MINUTES=1440

# Fréquence de rafraîchissement des records (commun + individuel) figés en BDD.
# 60 = 1 recompute / heure. Un refresh est aussi déclenché après chaque import
# de logs delivery, donc cet intervalle ne sert que de filet de sécurité.
RECORDS_REFRESH_INTERVAL_MINUTES=60

# Durée de validité d'une session en jours
SESSION_DURATION_DAYS=14

# Timezone du process Node. Par défaut Europe/Paris — garantit que toutes les
# dates affichées (et le calcul de semaine ISO) soient cohérentes avec Google
# Sheets, peu importe la TZ du serveur (souvent UTC en prod).
TZ=Europe/Paris
